# Copy this file to test/kvm/talos.local.env and adjust paths for your machine.

# Example 1: boot from a reusable qcow2 base image by creating an overlay in test/state/.
# BASE_IMAGE=/absolute/path/to/base-image.qcow2

# Example 2: boot from an installer ISO with a fresh test disk.
# BOOT_ISO=/absolute/path/to/installer.iso

# Example 3: boot from an existing writable disk image directly.
# DISK_IMAGE=/absolute/path/to/existing-disk.qcow2

# Optional: attach a seed ISO or other config media.
# CLOUD_INIT_ISO=/absolute/path/to/seed.iso
